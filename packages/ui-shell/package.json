{
  "name": "@mavene/ui-shell",
  "version": "0.2.0",
  "description": "Shared shell chrome for the IoT Unified Platform — AppNavbar, AppDrawer, AppFooter, CommandPalette",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && node scripts/add-use-client.mjs",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@mavene/shared-types": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "peerDependencies": {
    "cmdk": ">=1",
    "lucide-react": ">=1",
    "next": ">=16",
    "radix-ui": ">=1.4",
    "react": ">=19"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.6",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
