{
  "name": "@iot-platform-saf/nav-config",
  "version": "0.1.0",
  "description": "Shared navigation configuration for the IoT Unified Platform — drawer items, linkType contract, and RBAC permission arrays",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@iot-platform-saf/shared-types": ">=0.3.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
